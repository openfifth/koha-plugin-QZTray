{
  "/certificate": {
    "get": {
      "x-mojo-to": "Com::OpenFifth::QZTray::Controllers::Auth#getCertificate",
      "operationId": "getCertificate",
      "tags": [
        "qztray-auth"
      ],
      "produces": [
        "text/plain"
      ],
      "responses": {
        "200": {
          "description": "Certificate retrieved successfully",
          "schema": {
            "type": "string",
            "description": "The PEM formatted digital certificate"
          }
        },
        "404": {
          "description": "Certificate not configured",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        },
        "500": {
          "description": "Internal server error",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        }
      }
    }
  },
  "/sign": {
    "post": {
      "x-mojo-to": "Com::OpenFifth::QZTray::Controllers::Auth#signMessage",
      "operationId": "signMessage",
      "tags": [
        "qztray-auth"
      ],
      "produces": [
        "text/plain"
      ],
      "consumes": [
        "application/json"
      ],
      "parameters": [
        {
          "name": "body",
          "in": "body",
          "required": true,
          "description": "Message to sign",
          "schema": {
            "type": "object",
            "required": [
              "message"
            ],
            "properties": {
              "message": {
                "type": "string",
                "description": "The message to be signed"
              }
            }
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Message signed successfully",
          "schema": {
            "type": "string",
            "description": "Base64 encoded signature"
          }
        },
        "400": {
          "description": "Missing message parameter",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        },
        "404": {
          "description": "Private key not configured",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        },
        "500": {
          "description": "Signing failed",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        }
      }
    }
  },
  "/log-error": {
    "post": {
      "x-mojo-to": "Com::OpenFifth::QZTray::Controllers::Auth#logError",
      "operationId": "logError",
      "tags": [
        "qztray-logging"
      ],
      "produces": [
        "application/json"
      ],
      "consumes": [
        "application/json"
      ],
      "parameters": [
        {
          "name": "body",
          "in": "body",
          "required": true,
          "description": "Error information to log",
          "schema": {
            "type": "object",
            "required": [
              "error"
            ],
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message to log"
              },
              "context": {
                "type": "string",
                "description": "Context where error occurred"
              },
              "user_agent": {
                "type": "string",
                "description": "User agent string"
              },
              "page_url": {
                "type": "string",
                "description": "URL where error occurred"
              }
            }
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Error logged successfully",
          "schema": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "description": "Success status"
              }
            }
          }
        },
        "400": {
          "description": "Invalid request data",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        },
        "500": {
          "description": "Internal server error",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        }
      }
    }
  },
  "/log-printer": {
    "post": {
      "x-mojo-to": "Com::OpenFifth::QZTray::Controllers::Auth#logPrinter",
      "operationId": "logPrinter",
      "tags": [
        "qztray-logging"
      ],
      "produces": [
        "application/json"
      ],
      "consumes": [
        "application/json"
      ],
      "parameters": [
        {
          "name": "body",
          "in": "body",
          "required": true,
          "description": "Printer discovery information to log",
          "schema": {
            "type": "object",
            "required": [
              "printers"
            ],
            "properties": {
              "printers": {
                "type": "array",
                "description": "List of printer names discovered",
                "items": {
                  "type": "string"
                }
              },
              "register_id": {
                "type": "string",
                "description": "Register ID from session"
              },
              "page_url": {
                "type": "string",
                "description": "URL where printers were discovered"
              }
            }
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Printer usage logged successfully",
          "schema": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "description": "Success status"
              }
            }
          }
        },
        "400": {
          "description": "Invalid request data",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        },
        "500": {
          "description": "Internal server error",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        }
      }
    }
  },
  "/log-connection": {
    "post": {
      "x-mojo-to": "Com::OpenFifth::QZTray::Controllers::Auth#logConnection",
      "operationId": "logConnection",
      "tags": [
        "qztray-logging"
      ],
      "produces": [
        "application/json"
      ],
      "consumes": [
        "application/json"
      ],
      "parameters": [
        {
          "name": "body",
          "in": "body",
          "required": true,
          "description": "QZ Tray connection failure diagnostics to log",
          "schema": {
            "type": "object",
            "required": [
              "failure_type"
            ],
            "properties": {
              "category": {
                "type": "string",
                "description": "Diagnostic category: 'connection' or 'drawer'"
              },
              "failure_type": {
                "type": "string",
                "description": "Failure type, e.g. 'timeout', 'error', 'printer_not_found'"
              },
              "printer": {
                "type": "string",
                "description": "Printer name involved in a drawer failure, if any"
              },
              "error_message": {
                "type": "string",
                "description": "Underlying error message, if any"
              },
              "error_name": {
                "type": "string",
                "description": "Underlying error name/type, if any"
              },
              "timeout_ms": {
                "type": "integer",
                "x-nullable": true,
                "description": "Probe timeout in milliseconds (timeout failures only)"
              },
              "secure_context": {
                "type": "boolean",
                "x-nullable": true,
                "description": "Whether the page was served in a secure context"
              },
              "user_agent": {
                "type": "string",
                "description": "Browser user agent string"
              },
              "register_id": {
                "type": "string",
                "description": "Register ID from session"
              },
              "page_url": {
                "type": "string",
                "description": "URL where the connection failure occurred"
              }
            }
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Connection failure logged successfully",
          "schema": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "description": "Success status"
              }
            }
          }
        },
        "400": {
          "description": "Invalid request data",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        },
        "500": {
          "description": "Internal server error",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        }
      }
    }
  },
  "/set-register-printer": {
    "post": {
      "x-mojo-to": "Com::OpenFifth::QZTray::Controllers::Auth#setRegisterPrinter",
      "operationId": "setRegisterPrinter",
      "tags": [
        "qztray-config"
      ],
      "produces": [
        "application/json"
      ],
      "consumes": [
        "application/json"
      ],
      "parameters": [
        {
          "name": "body",
          "in": "body",
          "required": true,
          "description": "Register to printer mapping to persist",
          "schema": {
            "type": "object",
            "required": [
              "printer"
            ],
            "properties": {
              "register_id": {
                "type": "string",
                "description": "Register ID to map (falls back to session register if omitted)"
              },
              "printer": {
                "type": "string",
                "description": "Printer name to use for this register"
              }
            }
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Mapping saved successfully",
          "schema": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "description": "Success status"
              },
              "register_id": {
                "type": "string",
                "description": "Register the mapping was saved for"
              },
              "printer": {
                "type": "string",
                "description": "Sanitised printer name that was stored"
              }
            }
          }
        },
        "400": {
          "description": "Invalid request data",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        },
        "404": {
          "description": "Register not found",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        },
        "500": {
          "description": "Internal server error",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "error_code": {
                "type": "string",
                "description": "Machine-readable error code"
              }
            }
          }
        }
      }
    }
  }
}
